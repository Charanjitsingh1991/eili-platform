# =============================================================================
# EILI Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# =============================================================================

# --- Supabase (required) ---
# Get from: Supabase dashboard → Settings → API
# Auto-injected in Vercel if using Vercel↔Supabase integration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Get from: Supabase dashboard → Settings → API → service_role (secret)
# Server-side only. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database (required for Drizzle migrations) ---
# Get from: Supabase dashboard → Settings → Database → Connection string
# Use the "Transaction" pooler URL for DATABASE_URL
# Use the "Session" pooler or direct URL for DIRECT_URL
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# --- Site URL (required) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- PostHog Analytics (optional — analytics disabled if missing) ---
# Get from: PostHog → Project Settings → Project API Key
# Use EU region: eu.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Resend Email (optional — Supabase built-in SMTP used if missing) ---
# Get from: Resend dashboard → API Keys
RESEND_API_KEY=

# --- Sentry (DEFERRED — add before first public traffic) ---
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
